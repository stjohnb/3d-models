{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/St-John-Software/3d-models/blob/main/meta.schema.json",
  "title": "3D Model Project Metadata",
  "description": "Per-project metadata for 3D printable model collections.",
  "type": "object",
  "properties": {
    "description": {
      "type": "string",
      "description": "Human-readable project description."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "description": "Categories or tags for filtering (e.g. \"toy-parts\", \"organizer\")."
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semver version string."
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier override (repo default is implied when absent)."
    },
    "difficulty": {
      "type": "string",
      "enum": ["beginner", "intermediate", "advanced"],
      "description": "Print difficulty rating."
    },
    "hardware": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "item": { "type": "string", "description": "Hardware part name." },
          "quantity": { "type": "integer", "minimum": 1, "description": "Number required." },
          "notes": { "type": "string", "description": "Optional notes about this part." }
        },
        "required": ["item", "quantity"],
        "additionalProperties": false
      },
      "description": "Bill of materials for non-printed parts."
    },
    "relatedModels": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true,
      "description": "Directory names of related projects in this repo."
    },
    "mating_pairs": {
      "type": "array",
      "items": {
        "type": "array",
        "items": { "type": "string" },
        "minItems": 2,
        "maxItems": 2
      },
      "description": "Pairs of STL filenames (as rendered) that must fit together without geometric overlap."
    },
    "complex_interior": {
      "type": "boolean",
      "description": "Whether this model has significant interior cavities that a single isometric thumbnail cannot adequately convey. When true, CI renders additional orthographic views (top, bottom, front) alongside the standard isometric thumbnail."
    }
  },
  "required": ["description"],
  "additionalProperties": false
}
